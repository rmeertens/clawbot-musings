# Jira integration for tech-news (optional; used by tech-news/update_feed.py)
# Copy this to .env and fill in values — never commit .env to the repo.
# In production, set these as environment variables in the scheduled trigger settings.

JIRA_DOMAIN=infoqnews.atlassian.net
JIRA_USER_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=MLDE
